# Server
PORT=8787

# ---------- Baidu Qianfan Coding (OpenAI-compatible protocol) ----------
# Protocol: POST {BASE}/chat/completions
# Keep BASE without trailing slash and without /chat/completions
OPENAI_BASE_URL=https://qianfan.baidubce.com/v2/coding
# Usually minimax-m2.5 when selecting MiniMax-M2.5 in console (confirm exact model name there)
VISION_MODEL=minimax-m2.5
# Paste full key from console (example: bce-v3/ALTAKSP-xxx/xxx)
OPENAI_API_KEY=

# If token parameter mismatch occurs, try max_completion_tokens instead of max_tokens
# VISION_USE_MAX_COMPLETION_TOKENS=0

# Output token cap
# VISION_MAX_TOKENS=1200

# Anthropic-compatible endpoint is not used in this project

# Dev: set to 1 to simulate moderation rejection
# MOCK_MODERATION_FAIL=0

# Upload retention (hours)
# UPLOAD_TTL_HOURS=24
