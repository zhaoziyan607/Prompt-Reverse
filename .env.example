# Server
PORT=8787

# ---------- 百度智能云千帆 Coding Plan（OpenAI 兼容协议）----------
# 协议：与 OpenAI Chat Completions 相同，请求 POST {BASE}/chat/completions
# Base URL 不要带末尾斜杠，不要带 /chat/completions（代码会自动拼接）
OPENAI_BASE_URL=https://qianfan.baidubce.com/v2/coding
# 控制台选择 GLM-5 时通常为 glm-5（以控制台展示的 model 名为准）
VISION_MODEL=glm-5
# 将控制台生成的完整 Key 粘贴到下面（示例：bce-v3/ALTAKSP-xxx/xxx）
OPENAI_API_KEY=

# 若接口报错与 max_tokens 字段有关，可改为 1 尝试使用 max_completion_tokens
# VISION_USE_MAX_COMPLETION_TOKENS=0

# 输出 token 上限
# VISION_MAX_TOKENS=1200

# Anthropic 兼容地址（https://qianfan.baidubce.com/anthropic/coding）与本项目请求格式不同，未使用

# Dev: set to 1 to simulate moderation rejection
# MOCK_MODERATION_FAIL=0

# Upload retention (hours)
# UPLOAD_TTL_HOURS=24
